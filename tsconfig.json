{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["index.ts"],
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
