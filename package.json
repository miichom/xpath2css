{
  "name": "@miichom/xpath2css",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight converter that transforms XPath selectors into CSS selectors.",
  "keywords": [
    "xpath",
    "css selector",
    "xpath to css",
    "transform",
    "scraping",
    "crawler",
    "node",
    "deno"
  ],
  "homepage": "https://github.com/miichom/xpath2css",
  "bugs": {
    "url": "https://github.com/miichom/xpath2css/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miichom/xpath2css.git"
  },
  "license": "MIT",
  "author": "miichom <hello@cammy.xyz> (https://cammy.xyz/)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown",
    "format": "biome format --write",
    "lint": "biome check --write",
    "lint:check": "biome check",
    "test:bun": "bun test tests/bun.test.ts",
    "test:deno": "deno task test",
    "test:node": "vitest --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.9",
    "linkedom": "^0.18.12",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
